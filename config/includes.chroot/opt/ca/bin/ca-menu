#!/bin/bash
set -euo pipefail

trap 'exit 130' INT   # Ctrl-C: exit and let systemd restart the menu
trap 'exit 0'   TERM  # systemd stop (e.g. shutdown): exit cleanly, no restart

if [[ $EUID -ne 0 ]]; then
    echo "ca-menu must be run as root." >&2
    exit 1
fi

PRIVATE_DIR=/mnt/cadata/ca/private
CERTS_DIR=/mnt/cadata/ca/certs
USB_MOUNT=/media/usb
USB_CERTS_DIR=$USB_MOUNT/certs
USB_REQUESTS_DIR=$USB_MOUNT/requests
AUDIT_LOG=menu.log
AUDIT_DIR=/mnt/cadata/audit
# ── Helpers ───────────────────────────────────────────────────────────────────

log() {
    audit-log "$AUDIT_LOG" "$*"
}

pause() {
    echo ""
    read -rp "Press Enter to continue..."
}

usb_mounted() {
    mountpoint -q "$USB_MOUNT" 2>/dev/null
}

cadata_ready() {
    mountpoint -q /mnt/cadata 2>/dev/null
}

# True if the CA data partition exists and has a LUKS header.
cadata_has_luks() {
    local part
    part=$(find_cadata_partition 2>/dev/null) || return 1
    cryptsetup isLuks "$part" 2>/dev/null
}

# Print the path to partition 2 of the live boot medium (the CA data slot).
# Works for real USB boot and QEMU cdrom-boot testing.
find_cadata_partition() {
    local source disk part

    # Primary: where live-boot mounted the medium
    source=$(findmnt -n -o SOURCE /run/live/medium 2>/dev/null) || true

    # If booted from cdrom (QEMU) or medium detection failed, find by ISO 9660
    if [[ -z "$source" ]] || [[ "$source" == /dev/sr* ]]; then
        source=$(blkid -t TYPE=iso9660 -o device 2>/dev/null \
                 | grep -v '^/dev/sr' | head -1) || true
    fi

    [[ -z "$source" ]] && return 1

    # Resolve to parent disk
    disk=$(lsblk -no pkname "$source" 2>/dev/null) || true
    [[ -z "$disk" ]] && disk=$(basename "$source")

    part="/dev/${disk}2"
    [[ -b "$part" ]] && { echo "$part"; return 0; }
    return 1
}

# Return the RSA bit size for a private key file, or "?" on failure.
key_bits() {
    openssl pkey -in "$1" -text -noout 2>/dev/null \
        | grep -oP '\d+(?= bit)' | head -1 || echo "?"
}

# Return the RSA bit size for a public key file, or "?" on failure.
pubkey_bits() {
    openssl pkey -pubin -in "$1" -text -noout 2>/dev/null \
        | grep -oP '\d+(?= bit)' | head -1 || echo "?"
}

# ── Unlock ────────────────────────────────────────────────────────────────────

do_unlock_cadata() {
    local part
    part=$(find_cadata_partition)

    echo "  Enter passphrase to unlock CA data partition."
    echo ""

    if cryptsetup open "$part" cadata; then
        mount /dev/mapper/cadata /mnt/cadata
        log "STARTUP"
        return 0
    else
        cryptsetup close cadata 2>/dev/null || true
        return 1
    fi
}

# ── Initialization ────────────────────────────────────────────────────────────

do_init_cadata() {
    echo ""
    echo "=== Initialize CA data partition ==="
    echo ""

    local part
    if ! part=$(find_cadata_partition); then
        echo "  ERROR: Cannot locate CA data partition."
        echo "  Expected partition 2 of the live boot device."
        return
    fi

    local part_size
    part_size=$(lsblk -no SIZE "$part" 2>/dev/null | tr -d ' ') || part_size="unknown"
    echo "  Found CA data partition: $part ($part_size)"
    local existing_type
    existing_type=$(blkid -o value -s TYPE "$part" 2>/dev/null) || true
    if [[ -n "$existing_type" ]]; then
        echo "  WARNING: Partition already contains a $existing_type filesystem."
        echo "  Continuing will permanently destroy all existing CA data."
        echo ""
        read -rp "  Type 'yes' to destroy existing data and re-initialize: " confirm
    else
        echo ""
        echo "  This will format $part with LUKS2 encryption."
        echo "  Choose a strong passphrase — it will be required at every boot."
        echo "  The passphrase is not stored anywhere; keep it safe."
        echo ""
        read -rp "  Type 'yes' to proceed: " confirm
    fi
    [[ "$confirm" == "yes" ]] || { echo "  Aborted."; return; }

    echo ""
    local passphrase passphrase2
    read -rsp "  Passphrase: " passphrase; echo
    read -rsp "  Confirm passphrase: " passphrase2; echo
    if [[ "$passphrase" != "$passphrase2" ]]; then
        echo "  Passphrases do not match."
        return
    fi
    if [[ -z "$passphrase" ]]; then
        echo "  Passphrase cannot be empty."
        return
    fi

    echo ""
    echo "  Passphrase set. Formatting and setting up filesystem..."
    printf '%s' "$passphrase" | cryptsetup luksFormat --type luks2 --batch-mode --pbkdf-memory 262144 --key-file - "$part"

    printf '%s' "$passphrase" | cryptsetup open --key-file - "$part" cadata-init

    mkfs.ext4 -q /dev/mapper/cadata-init

    local mntdir
    mntdir=$(mktemp -d)
    mount /dev/mapper/cadata-init "$mntdir"

    mkdir -p \
        "$mntdir/ca/private" \
        "$mntdir/ca/certs" \
        "$mntdir/ca/newcerts" \
        "$mntdir/ca/crl" \
        "$mntdir/ca/csr" \
        "$mntdir/audit"
    chmod 700 "$mntdir/ca/private"

    umount "$mntdir"
    rmdir "$mntdir"
    cryptsetup close cadata-init

    echo ""
    echo "  CA data partition initialized successfully."
    echo "  You will be prompted for the passphrase on every boot."
    echo ""
    read -rp "  Reboot now? [Y/n]: " reboot_confirm
    [[ "$reboot_confirm" =~ ^[Nn]$ ]] || reboot
}

# ── Operations ────────────────────────────────────────────────────────────────

do_create_keypair() {
    echo ""
    echo "=== Create CA keypair ==="
    echo ""

    read -rp "  RID (10 hexadecimal digits): " rid
    if [[ -z "$rid" || ! "$rid" =~ ^[0-9a-fA-F]{10}$ ]]; then
        echo "  Invalid RID. Must be exactly 10 hexadecimal digits."
        return
    fi

    read -rp "  Index (digits only): " index
    if [[ -z "$index" || ! "$index" =~ ^[0-9]+$ ]]; then
        echo "  Invalid index."
        return
    fi

    local name="${rid}-${index}"
    if [[ -f "$PRIVATE_DIR/$name.key.pem" ]]; then
        echo "  A keypair named '$name' already exists."
        return
    fi

    echo ""
    echo "  Public exponent:"
    echo "    1) 3"
    echo "    2) 65537"
    read -rp "  Select [1/2]: " exp_choice
    local exponent
    case "$exp_choice" in
        1) exponent=3 ;;
        2) exponent=65537 ;;
        *)
            echo "  Invalid selection."
            return
            ;;
    esac

    local key_size
    while true; do
        read -rp "  Key size in bits (1024–2048, multiples of 8): " key_size
        if [[ "$key_size" =~ ^[0-9]+$ ]] \
            && [[ $key_size -ge 1024 ]] \
            && [[ $key_size -le 2048 ]] \
            && [[ $(( key_size % 8 )) -eq 0 ]]; then
            break
        fi
        echo "  Must be 1024–2048 and a multiple of 8."
    done

    local key_file="$PRIVATE_DIR/$name.key.pem"
    local pub_file="$CERTS_DIR/$name.pub.pem"

    echo ""
    echo "  Generating RSA-$key_size (e=$exponent)..."

    openssl genpkey \
        -algorithm RSA \
        -pkeyopt "rsa_keygen_bits:$key_size" \
        -pkeyopt "rsa_keygen_pubexp:$exponent" \
        -out "$key_file"

    chmod 400 "$key_file"

    openssl pkey -in "$key_file" -pubout -out "$pub_file"

    log "CREATE_KEYPAIR name=$name rid=$rid index=$index bits=$key_size exponent=$exponent"
    echo "  Keypair '$name' created."
}

do_list_keypairs() {
    echo ""
    echo "=== CA keypairs ==="
    echo ""

    shopt -s nullglob
    local files=("$PRIVATE_DIR"/*.key.pem)
    shopt -u nullglob

    if [[ ${#files[@]} -eq 0 ]]; then
        echo "  (none)"
        return
    fi

    printf "  %-10s  %-5s  %-19s  %s\n" "RID" "Index" "Created" "Bits"
    printf "  %-10s  %-5s  %-19s  %s\n" "──────────" "─────" "───────────────────" "────"
    for key_file in "${files[@]}"; do
        local stem rid index created bits
        stem=$(basename "$key_file" .key.pem)
        rid="${stem%-*}"
        index="${stem##*-}"
        created=$(stat -c '%y' "$key_file" | cut -d'.' -f1)
        bits=$(key_bits "$key_file")
        printf "  %-10s  %-5s  %-19s  %s\n" "$rid" "$index" "$created" "$bits"
    done
}

do_export_pubkey() {
    echo ""
    echo "=== Export CA public key ==="
    echo ""

    if ! usb_mounted; then
        echo "  No USB device mounted."
        return
    fi

    shopt -s nullglob
    local files=("$PRIVATE_DIR"/*.key.pem)
    shopt -u nullglob

    if [[ ${#files[@]} -eq 0 ]]; then
        echo "  No CA keypairs found."
        return
    fi

    echo "  Available keypairs:"
    printf "    %-10s  %s\n" "RID" "Index"
    printf "    %-10s  %s\n" "──────────" "─────"
    for f in "${files[@]}"; do
        local stem frid fidx
        stem=$(basename "$f" .key.pem)
        frid="${stem%-*}"
        fidx="${stem##*-}"
        printf "    %-10s  %s\n" "$frid" "$fidx"
    done
    echo ""
    read -rp "  RID (10 hexadecimal digits): " rid
    if [[ -z "$rid" || ! "$rid" =~ ^[0-9a-fA-F]{10}$ ]]; then
        echo "  Invalid RID."
        return
    fi
    read -rp "  Index (digits only): " index
    if [[ -z "$index" || ! "$index" =~ ^[0-9]+$ ]]; then
        echo "  Invalid index."
        return
    fi

    local name="${rid}-${index}"
    local pub_file="$CERTS_DIR/$name.pub.pem"
    if [[ ! -f "$pub_file" ]]; then
        echo "  No keypair named '$name'."
        return
    fi

    # Extract modulus (uppercase hex) and exponent from public key
    local modulus exponent_dec exponent_hex
    modulus=$(openssl rsa -pubin -in "$pub_file" -modulus -noout | cut -d= -f2)
    exponent_dec=$(openssl pkey -pubin -in "$pub_file" -text -noout \
        | grep 'Exponent:' | grep -oP '\d+' | head -1)
    exponent_hex=$(printf '%X' "$exponent_dec")
    (( ${#exponent_hex} % 2 != 0 )) && exponent_hex="0${exponent_hex}"

    # Pad index to even length for hex stream used in checksum
    local index_hex="$index"
    (( ${#index_hex} % 2 != 0 )) && index_hex="0${index_hex}"

    local checksum
    checksum=$(printf '%s' "${rid^^}${index_hex}${modulus}${exponent_hex}" \
        | xxd -r -p | sha1sum | awk '{print toupper($1)}')

    mkdir -p "$USB_CERTS_DIR"
    cp "$pub_file" "$USB_CERTS_DIR/$name.pub.pem"

    cat > "$USB_CERTS_DIR/$name.pub.json" <<EOF
{
    "rid": "${rid^^}",
    "index": "$index_hex",
    "modulus": "$modulus",
    "exponent": "$exponent_hex",
    "checksum": "$checksum"
}
EOF

    log "EXPORT_PUBKEY name=$name destination=$USB_CERTS_DIR"
    echo "  Exported to $USB_CERTS_DIR/$name.pub.pem"
    echo "  Exported to $USB_CERTS_DIR/$name.pub.json"
}

do_list_issuer_keys() {
    echo ""
    echo "=== Issuer public keys on USB ==="
    echo ""

    if ! usb_mounted; then
        echo "  No USB device mounted."
        return
    fi

    if [[ ! -d "$USB_REQUESTS_DIR" ]]; then
        echo "  No requests/ directory found on USB."
        echo ""
        echo "  Create a 'requests/' directory on the USB device and place"
        echo "  issuer request files inside it (any name ending in .csr.json)."
        return
    fi

    shopt -s nullglob
    local files=("$USB_REQUESTS_DIR"/*.csr.json)
    shopt -u nullglob

    if [[ ${#files[@]} -eq 0 ]]; then
        echo "  No issuer request files found."
        echo ""
        echo "  Place issuer public key request files in $USB_REQUESTS_DIR"
        echo "  (any name ending in .csr.json)."
        return
    fi

    printf "  %-24s  %-8s  %-6s  %s\n" "File" "PAN" "Seq#" "Bits"
    printf "  %-24s  %-8s  %-6s  %s\n" "────────────────────────" "────────" "──────" "────"
    for f in "${files[@]}"; do
        local name pan seq bits
        name=$(basename "$f" .csr.json)
        pan=$(jq -r '.applicationPan // "?"' "$f" 2>/dev/null)
        seq=$(jq -r '.certificateSequenceNumber // "?"' "$f" 2>/dev/null)
        bits=$(jq -r '.publicKey' "$f" 2>/dev/null \
            | openssl pkey -pubin -text -noout 2>/dev/null \
            | grep -oP '\d+(?= bit)' | head -1 || echo "?")
        printf "  %-24s  %-8s  %-6s  %s\n" "$name" "$pan" "$seq" "$bits"
    done
}

do_sign_issuer_key() {
    echo ""
    echo "=== Sign issuer public key ==="
    echo ""

    if ! usb_mounted; then
        echo "  No USB device mounted."
        return
    fi

    # ── Select issuer public key ───────────────────────────────────────────────

    shopt -s nullglob
    local req_files=("$USB_REQUESTS_DIR"/*.csr.json)
    shopt -u nullglob

    if [[ ${#req_files[@]} -eq 0 ]]; then
        echo "  No issuer request files found in $USB_REQUESTS_DIR."
        return
    fi

    echo "  Available issuer requests:"
    printf "    %-24s  %-8s  %s\n" "File" "PAN" "Seq#"
    printf "    %-24s  %-8s  %s\n" "────────────────────────" "────────" "──────"
    for f in "${req_files[@]}"; do
        local fpan fseq
        fpan=$(jq -r '.applicationPan // "?"' "$f" 2>/dev/null)
        fseq=$(jq -r '.certificateSequenceNumber // "?"' "$f" 2>/dev/null)
        printf "    %-24s  %-8s  %s\n" "$(basename "$f" .csr.json)" "$fpan" "$fseq"
    done
    echo ""
    read -rp "  Issuer request name: " issuer_name
    local issuer_file="$USB_REQUESTS_DIR/${issuer_name%.csr.json}.csr.json"
    if [[ ! -f "$issuer_file" ]]; then
        echo "  File not found: $issuer_name"
        return
    fi

    local issuer_pan_raw issuer_seq_raw issuer_pubkey
    issuer_pan_raw=$(jq -r '.applicationPan' "$issuer_file" 2>/dev/null)
    issuer_seq_raw=$(jq -r '.certificateSequenceNumber' "$issuer_file" 2>/dev/null)
    issuer_pubkey=$(jq -r '.publicKey' "$issuer_file" 2>/dev/null)

    if [[ -z "$issuer_pan_raw" || "$issuer_pan_raw" == "null" \
       || -z "$issuer_seq_raw" || "$issuer_seq_raw" == "null" \
       || -z "$issuer_pubkey"  || "$issuer_pubkey"  == "null" ]]; then
        echo "  Malformed request file: missing required fields."
        return
    fi
    if [[ ! "$issuer_pan_raw" =~ ^[0-9]{3,8}$ ]]; then
        echo "  Invalid applicationPan '$issuer_pan_raw'. Must be 3-8 digits."
        return
    fi
    if [[ ! "$issuer_seq_raw" =~ ^[0-9]+$ ]]; then
        echo "  Invalid certificateSequenceNumber '$issuer_seq_raw'."
        return
    fi

    echo "  PAN: $issuer_pan_raw  Seq#: $issuer_seq_raw"

    local issuer_exp_dec
    issuer_exp_dec=$(printf '%s' "$issuer_pubkey" \
        | openssl pkey -pubin -text -noout 2>/dev/null \
        | grep 'Exponent:' | grep -oP '\d+' | head -1) || true
    if [[ -z "$issuer_exp_dec" ]]; then
        echo "  Could not read issuer public key from '$issuer_name'."
        return
    fi
    if [[ "$issuer_exp_dec" != "3" && "$issuer_exp_dec" != "65537" ]]; then
        echo "  Unsupported exponent $issuer_exp_dec. Must be 3 or 65537."
        return
    fi

    # ── Select CA keypair ──────────────────────────────────────────────────────

    shopt -s nullglob
    local ca_files=("$PRIVATE_DIR"/*.key.pem)
    shopt -u nullglob

    if [[ ${#ca_files[@]} -eq 0 ]]; then
        echo "  No CA keypairs found."
        return
    fi

    echo ""
    echo "  Available CA keypairs:"
    printf "    %-10s  %s\n" "RID" "Index"
    printf "    %-10s  %s\n" "──────────" "─────"
    for f in "${ca_files[@]}"; do
        local stem frid fidx
        stem=$(basename "$f" .key.pem)
        frid="${stem%-*}"
        fidx="${stem##*-}"
        printf "    %-10s  %s\n" "$frid" "$fidx"
    done
    echo ""
    read -rp "  RID (10 hexadecimal digits): " ca_rid
    if [[ -z "$ca_rid" || ! "$ca_rid" =~ ^[0-9a-fA-F]{10}$ ]]; then
        echo "  Invalid RID."
        return
    fi
    read -rp "  Index (digits only): " ca_index
    if [[ -z "$ca_index" || ! "$ca_index" =~ ^[0-9]+$ ]]; then
        echo "  Invalid index."
        return
    fi
    local ca_name="${ca_rid}-${ca_index}"
    local ca_key_file="$PRIVATE_DIR/$ca_name.key.pem"
    if [[ ! -f "$ca_key_file" ]]; then
        echo "  No CA keypair named '$ca_name'."
        return
    fi

    # ── BIN and sequence number (from request file) ───────────────────────────

    local bin issuer_pan seq_num
    bin="$issuer_pan_raw"
    issuer_pan=$(printf '%-8s' "$bin" | tr ' ' 'F')
    seq_num=$(printf '%06d' "$issuer_seq_raw")

    local csr_dir="/mnt/cadata/ca/csr"
    local cert_filename="${bin}-${seq_num}.cert.json"
    if [[ -f "$csr_dir/$cert_filename" ]]; then
        echo "  Sequence number $seq_num is already taken for BIN $bin."
        return
    fi

    # ── Certificate expiry ────────────────────────────────────────────────────

    read -rp "  Certificate expiry (MMYY, e.g. 0835): " cert_exp
    if [[ -z "$cert_exp" || ! "$cert_exp" =~ ^[0-9]{4}$ ]]; then
        echo "  Invalid expiry. Must be 4 digits in MMYY format."
        return
    fi

    # ── Build cert ────────────────────────────────────────────────────────────

    echo ""
    echo "  Signing..."

    local ca_modulus issuer_modulus
    ca_modulus=$(openssl rsa -in "$ca_key_file" -modulus -noout | cut -d= -f2)
    issuer_modulus=$(printf '%s' "$issuer_pubkey" | openssl rsa -pubin -modulus -noout | cut -d= -f2)

    local ca_len issuer_pk_bytes issuer_pk_len
    ca_len=$(( ${#ca_modulus} / 2 ))
    issuer_pk_bytes=$(( ${#issuer_modulus} / 2 ))
    issuer_pk_len=$(printf '%02X' "$issuer_pk_bytes")

    local issuer_pk_ext issuer_pk_exp_len
    if [[ "$issuer_exp_dec" == "3" ]]; then
        issuer_pk_ext="03"
        issuer_pk_exp_len="01"
    else
        issuer_pk_ext="010001"
        issuer_pk_exp_len="03"
    fi

    local left_hex_len issuer_pk_left issuer_pk_right
    left_hex_len=$(( (ca_len - 36) * 2 ))
    issuer_pk_left="${issuer_modulus:0:$left_hex_len}"
    issuer_pk_right="${issuer_modulus:$left_hex_len}"

    if [[ ${#issuer_pk_left} -lt $left_hex_len ]]; then
        local pad
        pad=$(printf '%0*s' "$(( left_hex_len - ${#issuer_pk_left} ))" '' | tr ' ' 'B')
        issuer_pk_left="${issuer_pk_left}${pad}"
    fi

    local cert_format="02"   # Issuer Public Key certificate
    local hash_alg="01"      # SHA-1
    local pk_alg="01"        # RSA
    local data_header="6A"
    local data_trailer="BC"

    local hash_data_hex hash
    hash_data_hex="${cert_format}${issuer_pan}${cert_exp}${seq_num}${hash_alg}${pk_alg}${issuer_pk_len}${issuer_pk_exp_len}${issuer_pk_left}${issuer_pk_right}${issuer_pk_ext}"
    hash=$(printf '%s' "$hash_data_hex" | xxd -r -p | sha1sum | awk '{print toupper($1)}')

    local sign_data_hex cert
    sign_data_hex="${data_header}${cert_format}${issuer_pan}${cert_exp}${seq_num}${hash_alg}${pk_alg}${issuer_pk_len}${issuer_pk_exp_len}${issuer_pk_left}${hash}${data_trailer}"
    cert=$(printf '%s' "$sign_data_hex" | xxd -r -p \
        | openssl pkeyutl -decrypt -inkey "$ca_key_file" -pkeyopt rsa_padding_mode:none \
        | xxd -p | tr -d '\n' | tr 'a-f' 'A-F')

    local cert_json
    cert_json="{
  \"issuerCertificate\": \"$cert\",
  \"signingCa\": \"$ca_name\"
}"

    mkdir -p "$csr_dir" "$USB_CERTS_DIR"
    printf '%s\n' "$cert_json" > "$csr_dir/$cert_filename"
    cp "$csr_dir/$cert_filename" "$USB_CERTS_DIR/$cert_filename"

    log "SIGN_ISSUER_KEY issuer=$(basename "$issuer_file") ca=$ca_name bin=$bin seq=$seq_num"
    echo "  Certificate: $cert_filename"
    echo "  Saved to USB: $USB_CERTS_DIR/$cert_filename"
}

do_read_audit_log() {
    echo ""
    echo "=== Read audit log ==="
    echo ""

    shopt -s nullglob
    local files=("$AUDIT_DIR"/*)
    shopt -u nullglob

    if [[ ${#files[@]} -eq 0 ]]; then
        echo "  (no logs found)"
        return
    fi

    echo "  Available logs:"
    for f in "${files[@]}"; do
        echo "    - $(basename "$f")"
    done
    echo ""
    read -rp "  Log name: " logname

    local log_file="$AUDIT_DIR/$logname"
    if [[ ! -f "$log_file" ]]; then
        echo "  Log '$logname' not found."
        return
    fi

    less "$log_file"
}

do_drop_to_shell() {
    echo ""
    echo "  Dropping to user shell. Type 'exit' to return to the menu."
    echo ""
    su - user
}

do_shutdown() {
    echo ""
    echo "=== Unmount and shutdown ==="
    echo ""

    if usb_mounted; then
        echo "  Unmounting USB..."
        umount "$USB_MOUNT"
        log "USB_UNMOUNT"
    fi

    if cadata_ready; then
        log "SHUTDOWN"
        umount /mnt/cadata
    fi
    cryptsetup close cadata 2>/dev/null || true

    echo "  Shutting down..."
    shutdown -h now
    sleep infinity  # wait for systemd to kill us
}

# ── Main loop ─────────────────────────────────────────────────────────────────

while true; do
    clear
    echo "╔══════════════════════════════════════════╗"
    echo "║          CA Key Management               ║"
    echo "╚══════════════════════════════════════════╝"
    echo ""

    if ! cadata_ready; then
        if cadata_has_luks; then
            # Initialized but locked — prompt for passphrase
            if ! do_unlock_cadata; then
                echo ""
                echo "  Incorrect passphrase."
                echo ""
                echo "  1) Try again"
                echo "  2) Shutdown"
                echo ""
                read -rp "  > " choice
                [[ "$choice" == "2" ]] && do_shutdown
            fi
        else
            # Not yet initialized
            echo "  CA data partition is not initialized."
            echo ""
            echo "  1) Initialize CA data partition"
            echo "  2) Shutdown"
            echo ""
            read -rp "  > " choice
            case "$choice" in
                1) do_init_cadata; pause ;;
                2) do_shutdown ;;
                *) echo "  Invalid option."; pause ;;
            esac
        fi
        continue
    fi

    keypair_count=$(find "$PRIVATE_DIR" -name "*.key.pem" 2>/dev/null | wc -l)
    if [[ $keypair_count -eq 0 ]]; then
        echo "  [!] No CA keypair — create one before signing"
    fi
    if ! usb_mounted; then
        echo "  [!] No USB device — insert USB storage device"
    fi

    echo ""
    echo "  1) Create CA keypair"
    echo "  2) List CA keypairs"
    echo "  3) Export CA public key"
    echo "  4) List issuer public keys on USB"
    echo "  5) Sign issuer public key"
    echo "  6) Read audit log"
    echo "  7) Drop to shell"
    echo "  8) Unmount and shutdown"
    echo ""
    read -rp "  > " choice

    case "$choice" in
        1) do_create_keypair ;;
        2) do_list_keypairs ;;
        3) do_export_pubkey ;;
        4) do_list_issuer_keys ;;
        5) do_sign_issuer_key ;;
        6) do_read_audit_log ;;
        7) do_drop_to_shell ;;
        8) do_shutdown ;;
        *) echo "  Invalid option." ;;
    esac

    if [[ "$choice" != "8" ]]; then
        pause
    fi
done
